# ==============================================================================
# ForenShield AI — 환경 변수 예시
# 사용: cp .env.example .env 후 값 채우기 (Git 커밋 금지)
# Spring Boot는 .env를 자동 로드하지 않습니다.
# 로컬 실행 전 PowerShell 예:
#   Get-Content .env | ForEach-Object { if ($_ -match '^(?!#)(.+?)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] } }
# ==============================================================================

# --- JWT (필수: 운영 / 권장: 로컬도 동일 키 사용) ---
# HS256 서명용. 최소 32바이트(문자) 이상의 랜덤 값.
# 생성 예 (PowerShell):
#   [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
# 생성 예 (OpenSSL):
#   openssl rand -base64 48
JWT_SECRET_KEY=
JWT_EXPIRATION_MS=86400000

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# --- RDS PostgreSQL (prod) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- RabbitMQ / AI worker (prod) ---
# RABBITMQ_HOST=
# ANALYSIS_WORKER_MODE=ai

# --- Blockchain anchor (prod: http + INF gateway URL) ---
# BLOCKCHAIN_ANCHOR_MODE=http
# BLOCKCHAIN_ANCHOR_URL=
# BLOCKCHAIN_ANCHOR_NETWORK=polygon
