#!/bin/sh
# Blocks committing secret env files. Install once per clone:
#   cp scripts/git/pre-commit-block-secrets .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit   (Git Bash / macOS / Linux)

staged=$(git diff --cached --name-only --diff-filter=ACMR)
blocked=$(printf '%s\n' "$staged" | grep -E '^\.env$|^\.env\.|config/secrets\.env$|^config/infra\.env$' || true)
# Template only — safe to commit (see repo .env.example)
blocked=$(printf '%s\n' "$blocked" | grep -vxF '.env.example' || true)

if [ -n "$blocked" ]; then
  echo "ERROR: Refusing to commit secret file(s):" >&2
  printf '%s\n' "$blocked" | sed 's/^/  - /' >&2
  echo "Use .env.example for templates. Keep secrets local only." >&2
  exit 1
fi

exit 0
