#!/bin/sh
# Blocks committing secret env files and key material.
# Install once per clone:
#   ./scripts/git/install-hooks.sh        (Git Bash / macOS / Linux)
#   pwsh ./scripts/git/install-hooks.ps1  (Windows PowerShell)

set -eu

staged=$(git diff --cached --name-only --diff-filter=ACMR)

blocked=$(printf '%s\n' "$staged" | grep -E \
  '(^|/)\.env$|(^|/)\.env\.|(^|/)config/secrets\.env$|(^|/)config/infra\.env$|\.(pem|key|p12|pfx)$|(^|/)crypto/' \
  || true)
blocked=$(printf '%s\n' "$blocked" | grep -vxF '.env.example' || true)
blocked=$(printf '%s\n' "$blocked" | grep -vxF 'config/infra.env.example' || true)

if [ -n "$blocked" ]; then
  echo "ERROR: Refusing to commit secret file(s):" >&2
  printf '%s\n' "$blocked" | sed 's/^/  - /' >&2
  echo "Use .env.example for templates. Keep keys/PEM local or in Secrets Manager." >&2
  exit 1
fi

key_files=$(git diff --cached --diff-filter=ACMR -G 'BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY' --name-only \
  -- ':(exclude)scripts/git/pre-commit-block-secrets' \
  ':(exclude).github/workflows/secret-scan.yml' \
  || true)
if [ -n "$key_files" ]; then
  echo "ERROR: Staged diff contains private key material:" >&2
  printf '%s\n' "$key_files" | sed 's/^/  - /' >&2
  exit 1
fi

content_diff=$(git diff --cached --diff-filter=ACMR \
  -- ':(exclude)scripts/git/pre-commit-block-secrets' \
  ':(exclude).github/workflows/secret-scan.yml' \
  || true)
if printf '%s\n' "$content_diff" | grep -E 'AKIA[0-9A-Z]{16}|aws_secret_access_key|BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY' >/dev/null 2>&1; then
  echo "ERROR: Staged diff looks like it contains credentials (AWS key or private key)." >&2
  exit 1
fi

exit 0
